DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OBSIDIAN_VAULT_PATH=D:\Obsidian\YourVault
OPENAI_API_KEY=your-openai-api-key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mastra_demo
DATABASE_SCHEMA=public
DATABASE_SSL=false
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_APPLICATION_ID=your-discord-application-id
# Optional: comma-separated role IDs that should also trigger mention handling.
DISCORD_MENTION_ROLE_IDS=
# Optional: comma-separated DNS servers used to resolve gateway.discord.gg when local DNS is unreliable.
DISCORD_GATEWAY_DNS_SERVERS=1.1.1.1,8.8.8.8
# Optional: manual IPv4 override for gateway.discord.gg if DNS is still blocked.
DISCORD_GATEWAY_IP=
# Optional: explicit proxy URL for Discord traffic, e.g. http://127.0.0.1:7897.
DISCORD_PROXY_URL=
MASTRA_JWT_SECRET=replace-with-a-long-random-secret
# Optional for local testing with Studio or curl. The token payload must include a sub claim.
MASTRA_JWT_TOKEN=your-jwt-token

